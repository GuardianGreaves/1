<Window x:Class="diplom_loskutova.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:iconPacks="http://metro.mahapps.com/winfx/xaml/iconpacks"
        WindowStartupLocation="CenterScreen" WindowStyle="None" Height="720" Width="1080"
        AllowsTransparency="True" Background="Transparent">

    <Window.Resources>
        <!-- Тень для верхней панели -->
        <DropShadowEffect x:Key="WindowShadow" Color="Gray" Direction="270" ShadowDepth="5" BlurRadius="10" Opacity="0.5"/>
    </Window.Resources>

    <Border Background="{StaticResource White}" 
            BorderBrush="#E0E6ED" 
            BorderThickness="1"
            Effect="{StaticResource WindowShadow}"
            Margin="10"
            MouseDown="Border_MouseDown">
        <DockPanel LastChildFill="True">
            <!-- Верхняя панель -->
            <Border DockPanel.Dock="Top" 
                    Background="{StaticResource LightBlue}"
                    BorderBrush="{StaticResource Blue200}" 
                    BorderThickness="0,0,0,1"
                    Padding="0">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>

                    <!-- Логин + Выход -->
                    <!-- Логин + Выход + ЛОГО -->
                    <StackPanel Grid.Row="0" Grid.Column="0" Orientation="Horizontal" Margin="15 10 5 5">
                        <!-- ЛОГО СЛЕВА -->
                        <Image Source="/K1EBQ-Photoroom.ico" Width="40" Height="40" Margin="0,0,15,0"/>

                        <!-- Логин -->
                        <StackPanel>
                            <TextBlock x:Name="nameUser" FontSize="18" FontWeight="SemiBold" Text="Иванов Иван Иванович"/>
                            <TextBlock x:Name="nameRole" FontSize="14" Text="(ограниченный доступ)"/>
                        </StackPanel>

                        <!-- Выход -->
                        <Button Background="Transparent" Width="32" Height="32" Margin="20,0,0,0" BorderThickness="0" Click="Button_Click">
                            <iconPacks:PackIconMaterial Kind="Logout" Width="20" Height="20"/>
                        </Button>
                    </StackPanel>

                    <!-- Кнопки управления окном -->
                    <StackPanel Grid.Row="0" Grid.Column="1" Orientation="Horizontal" 
                                HorizontalAlignment="Right" Margin="0 0 0 20">
                        <Button Style="{StaticResource ButtonWindowControl}" Width="36" Height="36" Click="Minimize_Click" Margin="0,0,4,0">
                            <iconPacks:PackIconMaterial Kind="WindowMinimize" Width="16" Height="16"/>
                        </Button>
                        <Button Style="{StaticResource ButtonWindowControl}" Width="36" Height="36" Click="Restore_Click" Margin="0,0,4,0">
                            <iconPacks:PackIconMaterial Kind="WindowRestore" Width="16" Height="16"/>
                        </Button>
                        <Button Style="{StaticResource ButtonWindowControl}" Width="36" Height="36" Click="Close_Click">
                            <iconPacks:PackIconMaterial Kind="Close" Width="16" Height="16"/>
                        </Button>
                    </StackPanel>

                    <!-- Меню -->
                    <StackPanel Orientation="Horizontal" Grid.Row="1" Grid.ColumnSpan="2" 
                                HorizontalAlignment="Left" Margin="0 5 0 5">
                        <Button Style="{StaticResource ButtomMenu}" Content="Заявки" Click="ButtonOpenPageApplication" Name="BtnOpenPageApplication"/>
                        <Button Style="{StaticResource ButtomMenu}" Content="Мероприятия" Click="ButtonOpenPageEvent" Name="BtnOpenPageEvent"/>
                        <Button Style="{StaticResource ButtomMenu}" Content="Граждане" Click="ButtonOpenPageCitizen" Name="BtnOpenPageCitizen"/>
                        <Button Style="{StaticResource ButtomMenu}" Content="Пользователи" Click="ButtonOpenPageUsers" Name="BtnOpenPageUsers"/>
                        <Button Style="{StaticResource ButtomMenu}" Content="Статус" Click="ButtonOpenPageStatus" Name="BtnOpenPageStatus"/>
                        <Button Style="{StaticResource ButtomMenu}" Content="Тип мероприятия" Click="ButtonOpenPageTypeEvent" Name="BtnOpenPageTypeEvent"/>
                        <Button Style="{StaticResource ButtomMenu}" Content="Роль пользователя" Click="ButtonOpenPageRoleUser" Name="BtnOpenPageRoleUser"/>
                        <Button Style="{StaticResource ButtomMenu}" Content="Отчеты" Click="ButtonOpenPageReports" Name="BtnOpenPageReports"/>
                        <Button Style="{StaticResource ButtomMenu}" Content="Настройки" Click="ButtonOpenPageSettings" Name="BtnOpenPageSettings"/>
                    </StackPanel>
                </Grid>
            </Border>

            <!-- Основной контент -->
            <Grid Background="{StaticResource LightGray}">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="95*"/>
                    <ColumnDefinition Width="55*"/>
                    <ColumnDefinition Width="928*"/>
                </Grid.ColumnDefinitions>

                <!-- Приветственный текст -->
                <Border x:Name="WelcomeText" Grid.ColumnSpan="3" Background="Transparent" 
        CornerRadius="16" Margin="20" Padding="40">
                    <StackPanel HorizontalAlignment="Center" 
                VerticalAlignment="Center">

                        <!-- Заголовок -->
                        <TextBlock FontSize="28" FontWeight="Bold"
                   Foreground="{StaticResource GrayText}"
                   HorizontalAlignment="Center"
                   Margin="0,0,0,20"
                   TextWrapping="Wrap">
            Приложение «Учёт мер социальной поддержки»
                        </TextBlock>

                        <!-- Основной текст с отступами -->
                        <TextBlock FontSize="20" FontWeight="Light"
                   Foreground="{StaticResource GrayText}"
                   TextAlignment="Left"
                   TextWrapping="Wrap" 
                   LineHeight="36"><Run Text="&#x9;ГАУ «КЦСОН Камышловского района» оказывает социальное обслуживание пожилым гражданам и инвалидам, организуя культурно-досуговые мероприятия для поддержания качества жизни."/><LineBreak/><Run Text="&#x9;Приложение «Учёт мер социальной поддержки» автоматизирует деятельность сотрудников ГАУ «КЦСОН Камышловского района» по организации культурно-досуговых мероприятий для граждан пожилого возраста."/><LineBreak/><Run Text="&#x9;В проекте рассматривается именно учёт мероприятий, так как это направление наименее автоматизировано — планирование кружков, обработка заявок и фиксация посещаемости ведутся в бумажных журналах и Excel, что требует больших временных затрат и приводит к ошибкам."/></TextBlock>

                    </StackPanel>
                </Border>

                <!-- Frame для страниц -->
                <Frame x:Name="mainFrame" 
                      Background="{StaticResource White}" 
                      NavigationUIVisibility="Hidden"
                      Visibility="Collapsed" 
                      Grid.ColumnSpan="3"/>
            </Grid>
        </DockPanel>
    </Border>
</Window>
