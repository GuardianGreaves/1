<Window x:Class="diplom_loskutova.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:iconPacks="http://metro.mahapps.com/winfx/xaml/iconpacks"
        WindowStartupLocation="CenterScreen" WindowStyle="None" Height="720" Width="1080"
        AllowsTransparency="True" Background="White">

    <Window.Resources>
        <!-- Бело-голубая цветовая схема -->
        <SolidColorBrush x:Key="PrimaryBlue" Color="#2196F3"/>
        <SolidColorBrush x:Key="LightBlue" Color="#E3F2FD"/>
        <SolidColorBrush x:Key="Blue50" Color="#BBDEFB"/>
        <SolidColorBrush x:Key="Blue100" Color="#90CAF9"/>
        <SolidColorBrush x:Key="Blue200" Color="#64B5F6"/>
        <SolidColorBrush x:Key="Blue300" Color="#42A5F5"/>
        <SolidColorBrush x:Key="Blue400" Color="#2196F3"/>
        <SolidColorBrush x:Key="Blue500" Color="#1E88E5"/>
        <SolidColorBrush x:Key="Blue600" Color="#1976D2"/>
        <SolidColorBrush x:Key="Blue700" Color="#1565C0"/>
        <SolidColorBrush x:Key="Blue800" Color="#0D47A1"/>
        <SolidColorBrush x:Key="White" Color="White"/>
        <SolidColorBrush x:Key="LightGray" Color="#F8F9FA"/>
        <SolidColorBrush x:Key="GrayText" Color="#6C757D"/>
        <SolidColorBrush x:Key="DarkText" Color="#2C3E50"/>

        <!-- Стиль кнопок управления окном -->
        <Style x:Key="ButtonWindowControl" TargetType="Button">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Foreground" Value="{StaticResource Blue600}"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="{StaticResource Blue100}"/>
                    <Setter Property="Foreground" Value="{StaticResource Blue700}"/>
                </Trigger>
                <Trigger Property="IsPressed" Value="True">
                    <Setter Property="Background" Value="{StaticResource Blue200}"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <!-- Стиль кнопок меню -->
        <Style x:Key="ButtomMenu" TargetType="Button">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Foreground" Value="{StaticResource Blue600}"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Margin" Value="7,0"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}" 
                                CornerRadius="10" 
                                BorderThickness="0"
                                Padding="7">
                            <ContentPresenter HorizontalAlignment="Center" 
                                            VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Background" Value="{StaticResource Blue50}"/>
                                <Setter Property="Foreground" Value="{StaticResource Blue700}"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter Property="Background" Value="{StaticResource Blue100}"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Тень для верхней панели -->
        <DropShadowEffect x:Key="WindowShadow" Color="Gray" Direction="270" ShadowDepth="2" BlurRadius="10" Opacity="0.3"/>
    </Window.Resources>

    <Border Background="{StaticResource White}" 
            BorderBrush="#E0E6ED" 
            BorderThickness="1"
            Effect="{StaticResource WindowShadow}">
        <DockPanel LastChildFill="True">
            <!-- Верхняя панель -->
            <Border DockPanel.Dock="Top" 
                    Background="{StaticResource LightBlue}"
                    BorderBrush="{StaticResource Blue200}" 
                    BorderThickness="0,0,0,1"
                    Padding="0">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>

                    <!-- Логин + Выход -->
                    <StackPanel Grid.Row="0" Grid.Column="0" Orientation="Horizontal" Margin="5 10 5 5">
                        <Button Background="Transparent" BorderThickness="0" Click="Button_Click" 
                                Width="32" Height="32" Margin="0,0,12,0">
                            <iconPacks:PackIconMaterial Kind="Logout" 
                                                      Width="20" Height="20"
                                                      Foreground="{StaticResource Blue600}"
                                                      RenderTransformOrigin="0.5,0.5">
                                <iconPacks:PackIconMaterial.RenderTransform>
                                    <ScaleTransform ScaleX="-1"/>
                                </iconPacks:PackIconMaterial.RenderTransform>
                            </iconPacks:PackIconMaterial>
                            <Button.Style>
                                <Style TargetType="Button">
                                    <Style.Triggers>
                                        <Trigger Property="IsMouseOver" Value="True">
                                            <Setter Property="Background" Value="{StaticResource Blue50}"/>
                                        </Trigger>
                                    </Style.Triggers>
                                </Style>
                            </Button.Style>
                        </Button>

                        <StackPanel>
                            <TextBlock x:Name="nameUser" 
                                     FontSize="18" FontWeight="SemiBold"
                                     Text="Иванов Иван Иванович" 
                                     Foreground="{StaticResource DarkText}"
                                     VerticalAlignment="Center"/>
                            <TextBlock x:Name="nameRole" 
                                     Foreground="{StaticResource GrayText}" 
                                     FontSize="14" 
                                     Text="(ограниченный доступ)"
                                     VerticalAlignment="Center"
                                     Margin="0,2,0,0"/>
                        </StackPanel>
                    </StackPanel>

                    <!-- Кнопки управления окном -->
                    <StackPanel Grid.Row="0" Grid.Column="1" Orientation="Horizontal" 
                                HorizontalAlignment="Right" Margin="0 0 0 20">
                        <Button Style="{StaticResource ButtonWindowControl}" Width="36" Height="36" Click="Minimize_Click" Margin="0,0,4,0">
                            <iconPacks:PackIconMaterial Kind="WindowMinimize" Width="16" Height="16"/>
                        </Button>
                        <Button Style="{StaticResource ButtonWindowControl}" Width="36" Height="36" Click="Restore_Click" Margin="0,0,4,0">
                            <iconPacks:PackIconMaterial Kind="WindowRestore" Width="16" Height="16"/>
                        </Button>
                        <Button Style="{StaticResource ButtonWindowControl}" Width="36" Height="36" Click="Close_Click">
                            <iconPacks:PackIconMaterial Kind="Close" Width="16" Height="16"/>
                        </Button>
                    </StackPanel>

                    <!-- Меню -->
                    <StackPanel Orientation="Horizontal" Grid.Row="1" Grid.ColumnSpan="2" 
                                HorizontalAlignment="Left" Margin="0 5 0 5">
                        <Button Style="{StaticResource ButtomMenu}" Content="Заявки" Click="ButtonOpenPageApplication" Name="BtnOpenPageApplication"/>
                        <Button Style="{StaticResource ButtomMenu}" Content="Мероприятия" Click="ButtonOpenPageEvent" Name="BtnOpenPageEvent"/>
                        <Button Style="{StaticResource ButtomMenu}" Content="Граждане" Click="ButtonOpenPageCitizen" Name="BtnOpenPageCitizen"/>
                        <Button Style="{StaticResource ButtomMenu}" Content="Пользователи" Click="ButtonOpenPageUsers" Name="BtnOpenPageUsers"/>
                        <Button Style="{StaticResource ButtomMenu}" Content="Статус" Click="ButtonOpenPageStatus" Name="BtnOpenPageStatus"/>
                        <Button Style="{StaticResource ButtomMenu}" Content="Тип мероприятия" Click="ButtonOpenPageTypeEvent" Name="BtnOpenPageTypeEvent"/>
                        <Button Style="{StaticResource ButtomMenu}" Content="Роль пользователя" Click="ButtonOpenPageRoleUser" Name="BtnOpenPageRoleUser"/>
                        <Button Style="{StaticResource ButtomMenu}" Content="Отчеты" Click="ButtonOpenPageReports" Name="BtnOpenPageReports"/>
                        <Button Style="{StaticResource ButtomMenu}" Content="Настройки" Click="ButtonOpenPageSettings" Name="BtnOpenPageSettings"/>
                    </StackPanel>
                </Grid>
            </Border>

            <!-- Основной контент -->
            <Grid Background="{StaticResource LightGray}">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="95*"/>
                    <ColumnDefinition Width="55*"/>
                    <ColumnDefinition Width="928*"/>
                </Grid.ColumnDefinitions>

                <!-- Приветственный текст -->
                <Border Grid.ColumnSpan="3" Background="Transparent" 
                        CornerRadius="16" Margin="20" Padding="40">
                    <TextBlock x:Name="WelcomeText" 
                              Text="Добро пожаловать&#x0a;&#x0a;Выберите раздел в меню для начала работы" 
                              FontSize="28" FontWeight="Light"
                              Foreground="{StaticResource GrayText}"
                              HorizontalAlignment="Center" 
                              VerticalAlignment="Center"
                              TextAlignment="Center"
                              TextWrapping="Wrap"
                              LineHeight="36"/>
                </Border>

                <!-- Frame для страниц -->
                <Frame x:Name="mainFrame" 
                      Background="{StaticResource White}" 
                      NavigationUIVisibility="Hidden"
                      Visibility="Collapsed" 
                      Grid.ColumnSpan="3"/>
            </Grid>
        </DockPanel>
    </Border>
</Window>
