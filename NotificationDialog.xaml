<Window x:Class="diplom_loskutova.NotificationDialog"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:iconPacks="http://metro.mahapps.com/winfx/xaml/iconpacks"
        WindowStartupLocation="CenterScreen" 
        Background="Transparent"
        AllowsTransparency="True"
        WindowStyle="None">

    <Window.Resources>
        <SolidColorBrush x:Key="Blue400" Color="#2196F3"/>
        <SolidColorBrush x:Key="Blue500" Color="#1E88E5"/>
        <SolidColorBrush x:Key="Blue600" Color="#1976D2"/>
        <SolidColorBrush x:Key="LightBlue" Color="#E3F2FD"/>
        <SolidColorBrush x:Key="White" Color="White"/>
        <SolidColorBrush x:Key="GrayText" Color="#6C757D"/>
        <SolidColorBrush x:Key="DarkText" Color="#2C3E50"/>
    </Window.Resources>

    <Border Background="{StaticResource White}"
            CornerRadius="16"
            BorderThickness="1"
            BorderBrush="#E0E6ED"
            Width="420" Height="240"
            Margin="0">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <!-- Заголовок -->
            <Border Grid.Row="0" Background="{StaticResource LightBlue}" 
                    CornerRadius="16,16,0,0" Padding="24,20">
                <StackPanel Orientation="Horizontal">
                    <iconPacks:PackIconMaterial Kind="ShieldAlert" 
                                              Width="28" Height="28"
                                              Foreground="{StaticResource Blue600}"
                                              Margin="0,0,16,0"/>
                    <TextBlock x:Name="title" Text="Слишком много попыток" 
                               FontSize="20" FontWeight="SemiBold"
                               Foreground="{StaticResource DarkText}"
                               VerticalAlignment="Center"/>
                </StackPanel>
            </Border>

            <!-- Сообщение -->
            <StackPanel Grid.Row="1" Margin="32,20">
                <TextBlock x:Name="text" Text="Больше 3 неудачных попыток" 
                           FontSize="16" FontWeight="SemiBold"
                           Foreground="{StaticResource DarkText}"
                           Margin="0,0,0,8"/>
                <TextBlock x:Name="description" Text="Для продолжения введите код с картинки" 
                           FontSize="14"
                           Foreground="{StaticResource GrayText}"
                           TextWrapping="Wrap"/>
            </StackPanel>

            <!-- Кнопка -->
            <Button Grid.Row="2" Content="Ок" 
                    Background="{StaticResource Blue400}"
                    Foreground="White"
                    BorderThickness="0"
                    FontSize="16" FontWeight="SemiBold"
                    Margin="20"
                    Cursor="Hand"
                    Width="40"
                    Height="30"
                    Click="Button_Click"
                    HorizontalAlignment="Right">
                <Button.Template>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}" CornerRadius="12">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Background" Value="{StaticResource Blue500}"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Button.Template>
            </Button>
        </Grid>
    </Border>
</Window>