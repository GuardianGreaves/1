<Window x:Class="diplom_loskutova.NotificationDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:iconPacks="http://metro.mahapps.com/winfx/xaml/iconpacks"
        WindowStartupLocation="CenterScreen" 
        Background="Transparent"
        AllowsTransparency="True"
        WindowStyle="None">

    <Window.Resources>

        <DropShadowEffect x:Key="WindowShadow" Color="Gray" Direction="270" ShadowDepth="5" BlurRadius="10" Opacity="0.5"/>

        <SolidColorBrush x:Key="Blue400" Color="#2196F3"/>
        <SolidColorBrush x:Key="Blue500" Color="#1E88E5"/>
        <SolidColorBrush x:Key="Blue600" Color="#1976D2"/>
        <SolidColorBrush x:Key="LightBlue" Color="#E3F2FD"/>
        <SolidColorBrush x:Key="White" Color="White"/>
        <SolidColorBrush x:Key="GrayText" Color="#6C757D"/>
        <SolidColorBrush x:Key="DarkText" Color="#2C3E50"/>

        <!-- Стиль кнопки диалога -->
        <Style x:Key="DialogButtonStyle" TargetType="Button">
            <Setter Property="Background" Value="{StaticResource Blue400}"/>
            <Setter Property="Foreground" Value="{StaticResource White}"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="FontSize" Value="16"/>
            <Setter Property="Width" Value="80"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Margin" Value="5"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="HorizontalAlignment" Value="Right"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}" 
                                CornerRadius="12" Padding="10">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Background" Value="{StaticResource Blue500}"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter Property="Background" Value="{StaticResource Blue600}"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

    </Window.Resources>

    <Border Background="{StaticResource White}"
            Effect="{StaticResource WindowShadow}"
            CornerRadius="16"
            BorderThickness="1"
            BorderBrush="#E0E6ED"
            Width="420" Height="250"
            Margin="10"
            MouseDown="Border_MouseDown">
        <Grid Cursor="Hand">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <!-- Заголовок -->
            <Border Grid.Row="0" Background="{StaticResource LightBlue}" 
                    CornerRadius="16,16,0,0" Padding="24,20">
                <StackPanel Orientation="Horizontal">
                    <iconPacks:PackIconMaterial Kind="ShieldAlert" 
                                              Width="28" Height="28"
                                              Foreground="{StaticResource Blue600}"
                                              Margin="0,0,16,0"/>
                    <TextBlock x:Name="title" Text="Слишком много попыток" 
                               FontSize="20" FontWeight="SemiBold"
                               Foreground="{StaticResource DarkText}"
                               VerticalAlignment="Center"/>
                </StackPanel>
            </Border>

            <!-- Сообщение -->
            <StackPanel Grid.Row="1" Margin="32,20">
                <TextBlock x:Name="text" Text="Больше 3 неудачных попыток" 
                           FontSize="16" FontWeight="SemiBold"
                           Foreground="{StaticResource DarkText}"
                           Margin="0,0,0,8"/>
                <TextBlock x:Name="description" Text="Для продолжения введите код с картинки" 
                           FontSize="14"
                           Foreground="{StaticResource GrayText}"
                           TextWrapping="Wrap"/>
            </StackPanel>

            <!-- АДАПТИВНЫЕ КНОПКИ -->
            <StackPanel Grid.Row="2" Orientation="Horizontal" 
                        HorizontalAlignment="Right"
                        Margin="5">
                <!-- Кнопка ОК -->
                <Button x:Name="btnOK" Content="Oк" 
                        Style="{StaticResource DialogButtonStyle}"
                        Click="BtnOK_Click"
                        Visibility="Visible" IsDefault="True" Cursor="Hand"/>

                <!-- Кнопка Отмена -->
                <Button x:Name="btnCancel" Content="Отмена" 
                        Style="{StaticResource DialogButtonStyle}"
                        Click="BtnCancel_Click"
                        Visibility="Visible" IsCancel="True"/>
                
            </StackPanel>
        </Grid>
    </Border>
</Window>
