<Page x:Class="diplom_loskutova.Page.Reports"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
      xmlns:iconPacks="http://metro.mahapps.com/winfx/xaml/iconpacks"
      xmlns:local="clr-namespace:diplom_loskutova.Page"
      mc:Ignorable="d" 
      Title="Отчеты">

    <Grid Background="Transparent">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <!-- Заголовок + кнопки -->
            <RowDefinition Height="*"/>
            <!-- Контент -->
        </Grid.RowDefinitions>

        <!-- Заголовок -->
        <Grid Grid.Row="0" Margin="20 10">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <TextBlock Grid.Column="0" 
                       Text="Отчеты" 
                       FontSize="32" 
                       FontWeight="SemiBold"
                       Foreground="{StaticResource Blue600}"
                       VerticalAlignment="Center"/>
        </Grid>

        <!-- КАРТОЧКИ ОТЧЕТОВ -->
        <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto" Margin="0,0,0,20">
            <Grid Margin="20">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <!-- Сложные запросы -->
                    <RowDefinition Height="24"/>
                    <!-- Отступ -->
                    <RowDefinition Height="Auto"/>
                    <!-- Отчеты -->
                </Grid.RowDefinitions>

                <!-- СЛОЖНЫЕ ЗАПРОСЫ -->
                <Border Grid.Row="0" Background="{StaticResource White}" 
                        CornerRadius="20" Padding="0" Margin="0,0,0,16">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>

                        <!-- Заголовок секции -->
                        <StackPanel Grid.Row="0" Orientation="Horizontal" Margin="0,0,0,20">
                            <iconPacks:PackIconMaterial Kind="ChartLine" 
                                                      Width="28" Height="28"
                                                      Foreground="{StaticResource Blue600}"
                                                      Margin="0,0,16,0"/>
                            <TextBlock Text="Сложные запросы" 
                                       FontSize="24" FontWeight="SemiBold"
                                       Foreground="{StaticResource Blue600}"
                                       VerticalAlignment="Center"/>
                        </StackPanel>

                        <!-- Кнопки -->
                        <WrapPanel Grid.Row="1" Orientation="Horizontal">
                            <Button x:Name="Report1" Content="Уровень активности граждан" 
                                    Style="{StaticResource ActionButtonStyle}" 
                                    Width="280" Height="56" Margin="0,0,12,12"
                                    Click="Report1_Click"/>
                            <Button x:Name="Report2" Content="Реестр участников мероприятий" 
                                    Style="{StaticResource ActionButtonStyle}" 
                                    Width="280" Height="56" Margin="0,0,12,12"
                                    Click="Report2_Click"/>
                            <Button x:Name="Report3" Content="Список текущих мероприятий" 
                                    Style="{StaticResource ActionButtonStyle}" 
                                    Width="280" Height="56" Margin="0,0,12,12"
                                    Click="Report3_Click"/>
                            <Button x:Name="Report4" Content="Статистика удовлетворенности заявок" 
                                    Style="{StaticResource ActionButtonStyle}" 
                                    Width="280" Height="56" Margin="0,0,12,12"
                                    Click="Report4_Click"/>
                        </WrapPanel>
                    </Grid>
                </Border>

                <!-- ОТЧЕТЫ -->
                <Border Grid.Row="2" Background="{StaticResource White}" 
                        CornerRadius="20" Padding="0">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>

                        <!-- Заголовок секции -->
                        <StackPanel Grid.Row="0" Orientation="Horizontal" Margin="0,0,0,20">
                            <iconPacks:PackIconMaterial Kind="FileDocumentMultiple" 
                                                      Width="28" Height="28"
                                                      Foreground="{StaticResource Blue600}"
                                                      Margin="0,0,16,0"/>
                            <TextBlock Text="Отчеты" 
                                       FontSize="24" FontWeight="SemiBold"
                                       Foreground="{StaticResource Blue600}"
                                       VerticalAlignment="Center"/>
                        </StackPanel>

                        <!-- Кнопки -->
                        <WrapPanel Grid.Row="1" Orientation="Horizontal">
                            <Button x:Name="Report5" Content="Анализ персональных заявок" 
                                    Style="{StaticResource ActionButtonStyle}" 
                                    Width="280" Height="56" Margin="0,0,12,12"
                                    Click="Report5_Click"/>
                            <Button x:Name="Report6" Content="Статистика предоставленных услуг" 
                                    Style="{StaticResource ActionButtonStyle}" 
                                    Width="280" Height="56" Margin="0,0,12,12"
                                    Click="Report6_Click"/>
                            <Button x:Name="Report7" Content="Статистика проведенных мероприятий сотрудником" 
                                    Style="{StaticResource ActionButtonStyle}" 
                                    Width="280" Height="56" Margin="0,0,12,12"
                                    Click="Report7_Click"/>
                            <Button x:Name="Report8" Content="Рейтинг мероприятий по популярности" 
                                    Style="{StaticResource ActionButtonStyle}" 
                                    Width="280" Height="56" Margin="0,0,12,12"
                                    Click="Report8_Click"/>
                            <Button x:Name="Report9" Content="Бюджет по типам мероприятий" 
                                    Style="{StaticResource ActionButtonStyle}" 
                                    Width="280" Height="56" Margin="0,0,12,12"
                                    Click="Report9_Click"/>
                            <Button x:Name="Report10" Content="Эффективность мероприятий" 
                                    Style="{StaticResource ActionButtonStyle}" 
                                    Width="280" Height="56" Margin="0,0,12,12"
                                    Click="Report10_Click"/>
                            <Button x:Name="Report11" Content="Динамика подачи заявок" 
                                    Style="{StaticResource ActionButtonStyle}" 
                                    Width="280" Height="56" Margin="0,0,12,12"
                                    Click="Report11_Click"/>
                            <Button x:Name="Report12" Content="Топ активных участников" 
                                    Style="{StaticResource ActionButtonStyle}" 
                                    Width="280" Height="56" Margin="0,0,12,12"
                                    Click="Report12_Click"/>
                            <Button x:Name="Report13" Content="Нагрузка на социальных работников" 
                                    Style="{StaticResource ActionButtonStyle}" 
                                    Width="280" Height="56" Margin="0,0,12,12"
                                    Click="Report13_Click"/>
                            <Button x:Name="Report14" Content="Карточка гражданина" 
                                    Style="{StaticResource ActionButtonStyle}" 
                                    Width="280" Height="56" Margin="0,0,12,12"
                                    Click="Report13_Click"/>
                        </WrapPanel>
                    </Grid>
                </Border>
            </Grid>
        </ScrollViewer>
    </Grid>
</Page>
