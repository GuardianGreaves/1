<Page x:Class="diplom_loskutova.Page.Settings"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
      xmlns:iconPacks="http://metro.mahapps.com/winfx/xaml/iconpacks"
      mc:Ignorable="d" 
      Title="Настройки">

    <Page.Resources>
        <!-- Цветовая схема - ТОЧНО ТАК ЖЕ как в форме редактирования -->
        <SolidColorBrush x:Key="PrimaryBlue" Color="#2196F3"/>
        <SolidColorBrush x:Key="LightBlue" Color="#E3F2FD"/>
        <SolidColorBrush x:Key="Blue50" Color="#BBDEFB"/>
        <SolidColorBrush x:Key="Blue100" Color="#90CAF9"/>
        <SolidColorBrush x:Key="Blue200" Color="#64B5F6"/>
        <SolidColorBrush x:Key="Blue400" Color="#2196F3"/>
        <SolidColorBrush x:Key="Blue500" Color="#1E88E5"/>
        <SolidColorBrush x:Key="Blue600" Color="#1976D2"/>
        <SolidColorBrush x:Key="White" Color="White"/>
        <SolidColorBrush x:Key="LightGray" Color="#F8F9FA"/>
        <SolidColorBrush x:Key="GrayText" Color="#6C757D"/>
        <SolidColorBrush x:Key="DarkText" Color="#2C3E50"/>

        <!-- Стиль поля ввода - ТОЧНО ТАК ЖЕ -->
        <Style x:Key="FormFieldStyle" TargetType="Border">
            <Setter Property="Background" Value="{StaticResource White}"/>
            <Setter Property="CornerRadius" Value="12"/>
            <Setter Property="BorderThickness" Value="2"/>
            <Setter Property="BorderBrush" Value="{StaticResource GrayText}"/>
            <Setter Property="Padding" Value="10"/>
            <Setter Property="Margin" Value="0,8"/>
            <Setter Property="Width" Value="400"/>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="BorderBrush" Value="{StaticResource Blue200}"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <!-- Стиль кнопки - ТОЧНО ТАК ЖЕ -->
        <Style x:Key="FormButtonStyle" TargetType="Button">
            <Setter Property="Background" Value="{StaticResource Blue400}"/>
            <Setter Property="Foreground" Value="{StaticResource White}"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="FontSize" Value="16"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Margin" Value="10"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}" CornerRadius="12" Padding="10">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter Property="Background" Value="{StaticResource Blue600}"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Стиль кнопки назад - ТОЧНО ТАК ЖЕ -->
        <Style x:Key="BackButtonStyle" TargetType="Button">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="BorderBrush" Value="{StaticResource Blue400}"/>
            <Setter Property="Foreground" Value="{StaticResource Blue600}"/>
            <Setter Property="FontSize" Value="15"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}" 
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="10" Padding="10">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Background" Value="{StaticResource Blue50}"/>
                                <Setter Property="BorderBrush" Value="{StaticResource Blue600}"/>
                                <Setter Property="Foreground" Value="{StaticResource Blue600}"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Стиль лейблов формы -->
        <Style x:Key="FormLabelStyle" TargetType="TextBlock">
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Foreground" Value="{StaticResource DarkText}"/>
            <Setter Property="Margin" Value="0,0,0,4"/>
        </Style>
    </Page.Resources>

    <ScrollViewer VerticalScrollBarVisibility="Hidden" Margin="0">
        <Grid Style="{StaticResource DefaultPage}">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <!-- Верхняя панель -->
                <RowDefinition Height="Auto"/>
                <!-- Заголовок -->
                <RowDefinition Height="Auto"/>
                <!-- Форма -->
                <RowDefinition Height="*"/>
                <!-- Кнопки -->
            </Grid.RowDefinitions>


            <!-- Заголовок формы -->
            <TextBlock Grid.Row="1" 
                       Text="Настройки подключения к базе данных" 
                       Style="{StaticResource PageHeaderStyle}"
                       Margin="10"/>

            <!-- Форма настроек БД -->
            <Grid Grid.Row="2" Margin="10">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <!-- Левый столбец -->
                    <ColumnDefinition Width="*"/>
                    <!-- Правый столбец -->
                </Grid.ColumnDefinitions>

                <!-- ЛЕВЫЙ СТОЛБЕЦ -->
                <StackPanel Grid.Column="0" Margin="0,0,20,0">
                    <!-- Data Source -->
                    <TextBlock Text="Сервер (Data Source)" Style="{StaticResource FormLabelStyle}"/>
                    <Border Style="{StaticResource FormFieldStyle}">
                        <Grid>
                            <TextBox x:Name="DataSourceTextBox"
                                     VerticalAlignment="Center"
                                     Background="Transparent"
                                     BorderThickness="0"
                                     FontSize="18"
                                     Foreground="{StaticResource DarkText}"
                                     VerticalContentAlignment="Center"
                                     Padding="0,0,0,2"/>
                        </Grid>
                    </Border>

                    <!-- Initial Catalog -->
                    <TextBlock Text="База данных (Initial Catalog)" Style="{StaticResource FormLabelStyle}"/>
                    <Border Style="{StaticResource FormFieldStyle}">
                        <Grid>
                            <TextBox x:Name="InitialCatalogTextBox"
                                     VerticalAlignment="Center"
                                     Background="Transparent"
                                     BorderThickness="0"
                                     FontSize="18"
                                     Foreground="{StaticResource DarkText}"
                                     VerticalContentAlignment="Center"
                                     Padding="0,0,0,2"/>
                        </Grid>
                    </Border>
                </StackPanel>

                <!-- ПРАВЫЙ СТОЛБЕЦ -->
                <StackPanel Grid.Column="1">
                    <!-- Пользователь -->
                    <TextBlock Text="Пользователь" Style="{StaticResource FormLabelStyle}"/>
                    <Border Style="{StaticResource FormFieldStyle}">
                        <Grid>
                            <TextBox x:Name="UserTextBox"
                                     VerticalAlignment="Center"
                                     Background="Transparent"
                                     BorderThickness="0"
                                     FontSize="18"
                                     Foreground="{StaticResource DarkText}"
                                     VerticalContentAlignment="Center"
                                     Padding="0,0,0,2"/>
                        </Grid>
                    </Border>

                    <!-- Пароль -->
                    <TextBlock Text="Пароль" Style="{StaticResource FormLabelStyle}"/>
                    <Border Style="{StaticResource FormFieldStyle}">
                        <Grid>
                            <PasswordBox x:Name="PasswordBox"
                                         VerticalAlignment="Center"
                                         Background="Transparent"
                                         BorderThickness="0"
                                         FontSize="18"
                                         VerticalContentAlignment="Center"/>
                        </Grid>
                    </Border>
                </StackPanel>
            </Grid>

            <!-- Кнопки действий -->
            <StackPanel Grid.Row="3" Orientation="Horizontal" 
                        HorizontalAlignment="Right" 
                        Margin="10">
                <Button x:Name="InstructionsButton" 
                        Content="Инструкции" 
                        Style="{StaticResource FormButtonStyle}"
                        Width="160" Height="40"
                        Click="InstructionsButton_Click"/>
                <Button x:Name="TestConnectionButton" 
                        Content="Проверить подключение" 
                        Style="{StaticResource FormButtonStyle}"
                        Width="200" Height="40"
                        Click="TestConnectionButton_Click"/>
                <Button x:Name="SaveConnectionButton" 
                        Content="Сохранить" 
                        Style="{StaticResource FormButtonStyle}"
                        Width="160" Height="40"
                        Click="SaveConnectionButton_Click"/>
            </StackPanel>
        </Grid>
    </ScrollViewer>
</Page>
