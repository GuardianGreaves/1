<Page x:Class="diplom_loskutova.Page.Settings"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
      mc:Ignorable="d" 
      d:DesignHeight="450" d:DesignWidth="800"
      Title="Settings">

    <Grid Margin="5">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <Button Style="{StaticResource ButtomMenu}" Height="30" Grid.Row="0" HorizontalAlignment="Left">
            <TextBlock FontSize="15" Text="Настройки"/>
        </Button>

        <!-- Форма подключения к БД -->
        <Grid Grid.Row="1" Margin="0,10,0,0">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="150"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <TextBlock Grid.Row="0" Grid.Column="0" Margin="0,0,5,5" VerticalAlignment="Center" Text="Data Source:"/>
            <TextBox x:Name="DataSourceTextBox" Grid.Row="0" Grid.Column="1" Margin="0,0,0,5"/>

            <TextBlock Grid.Row="1" Grid.Column="0" Margin="0,0,5,5" VerticalAlignment="Center" Text="Initial Catalog:"/>
            <TextBox x:Name="InitialCatalogTextBox" Grid.Row="1" Grid.Column="1" Margin="0,0,0,5"/>

            <TextBlock Grid.Row="2" Grid.Column="0" Margin="0,0,5,5" VerticalAlignment="Center" Text="Пользователь:"/>
            <TextBox x:Name="UserTextBox" Grid.Row="2" Grid.Column="1" Margin="0,0,0,5"/>

            <TextBlock Grid.Row="3" Grid.Column="0" Margin="0,0,5,5" VerticalAlignment="Center" Text="Пароль:"/>
            <PasswordBox x:Name="PasswordBox" Grid.Row="3" Grid.Column="1" Margin="0,0,0,5"/>

            <StackPanel Grid.Row="4" Grid.ColumnSpan="2" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,10,0,0">
                <Button x:Name="TestConnectionButton" Content="Проверить подключение" Width="160" Margin="0,0,10,0" Click="TestConnectionButton_Click"/>
                <Button x:Name="SaveConnectionButton" Content="Сохранить" Width="100" Margin="0,0,10,0" Click="SaveConnectionButton_Click"/>
            </StackPanel>
            <Button Grid.Row="5" x:Name="InstructionsButton" Content="Инструкции" Width="100" Click="InstructionsButton_Click"/>
        </Grid>

    </Grid>
</Page>
