<Page x:Class="diplom_loskutova.Page.AddOrChange.EventsAOC"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
      xmlns:iconPacks="http://metro.mahapps.com/winfx/xaml/iconpacks"
      xmlns:local="clr-namespace:diplom_loskutova.Page.AddOrChange"
      mc:Ignorable="d" 
      Title="EventsAOC">


    <ScrollViewer VerticalScrollBarVisibility="Hidden" Margin="5">
        <Grid Background="Transparent">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <!-- Верхняя панель -->
                <RowDefinition Height="Auto"/>
                <!-- Заголовок -->
                <RowDefinition Height="Auto"/>
                <!-- Форма -->
                <RowDefinition Height="*"/>
                <!-- Кнопки -->
            </Grid.RowDefinitions>

            <!-- Верхняя панель с кнопками - ТОЧНО ТАК ЖЕ -->
            <StackPanel Grid.Row="0" Orientation="Horizontal" Margin="5">
                <Button Style="{StaticResource BackButtonStyle}" Click="BtnBack">
                    <StackPanel Orientation="Horizontal">
                        <iconPacks:PackIconMaterial Kind="ArrowLeft" 
                                                  Width="18" Height="18"
                                                  Margin="0,0,8,0"
                                                  VerticalAlignment="Center"/>
                        <TextBlock Text="Назад"/>
                    </StackPanel>
                </Button>

                <Button Style="{StaticResource ButtomMenu}" Height="44" Margin="16,0,0,0" IsEnabled="False">
                    <TextBlock x:Name="NamePage" FontSize="16" 
                               Text="Мероприятие - Добавить / Редактировать" FontWeight="SemiBold"/>
                </Button>
            </StackPanel>

            <!-- Заголовок формы - ТОЧНО ТАК ЖЕ -->
            <TextBlock Grid.Row="1" 
                       Text="Заполните данные мероприятия" 
                       Style="{StaticResource PageHeaderStyle}"/>

            <!-- Форма ввода данных - ТОЧНО ТАК ЖЕ -->
            <!-- Замени StackPanel на Grid -->
            <Grid Grid.Row="2" Margin="10">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <!-- Левый столбец -->
                    <ColumnDefinition Width="*"/>
                    <!-- Правый столбец -->
                </Grid.ColumnDefinitions>

                <!-- ЛЕВЫЙ СТОЛБЕЦ -->
                <StackPanel Grid.Column="0" Margin="0,0,20,0">
                    <!-- Пользователь -->
                    <TextBlock Text="Пользователь" 
                   Style="{StaticResource FormLabelStyle}"/>
                    <Border Style="{StaticResource FormFieldStyle}">
                        <Grid>
                            <ComboBox x:Name="ComboBoxUser"
                          VerticalAlignment="Center"
                          Background="Transparent"
                          BorderThickness="0"
                          FontSize="18"
                          Foreground="{StaticResource DarkText}"
                          VerticalContentAlignment="Center"
                          IsEditable="True"
                          Padding="0,0,0,2"/>
                        </Grid>
                    </Border>

                    <!-- Название -->
                    <TextBlock Text="Название" 
                   Style="{StaticResource FormLabelStyle}"/>
                    <Border Style="{StaticResource FormFieldStyle}">
                        <Grid>
                            <TextBox x:Name="TextBoxName"
                         VerticalAlignment="Center"
                         Background="Transparent"
                         BorderThickness="0"
                         FontSize="18"
                         Foreground="{StaticResource DarkText}"
                         VerticalContentAlignment="Center"
                         Padding="0,0,0,2"/>
                        </Grid>
                    </Border>

                    <!-- Дата -->
                    <TextBlock Text="Дата мероприятия" 
                   Style="{StaticResource FormLabelStyle}"/>
                    <Border Style="{StaticResource FormFieldStyle}">
                        <Grid>
                            <DatePicker x:Name="DatePickerDate"
                            VerticalAlignment="Center"
                            Background="Transparent"
                            BorderThickness="0"
                            FontSize="18"
                            VerticalContentAlignment="Center"/>
                        </Grid>
                    </Border>
                </StackPanel>

                <!-- ПРАВЫЙ СТОЛБЕЦ -->
                <StackPanel Grid.Column="1">
                    <!-- Тип мероприятия -->
                    <TextBlock Text="Тип мероприятия" 
                   Style="{StaticResource FormLabelStyle}"/>
                    <Border Style="{StaticResource FormFieldStyle}">
                        <Grid>
                            <ComboBox x:Name="ComboBoxTypeEvent"
                          VerticalAlignment="Center"
                          Background="Transparent"
                          BorderThickness="0"
                          FontSize="18"
                          Foreground="{StaticResource DarkText}"
                          VerticalContentAlignment="Center"
                          IsEditable="True"
                          Padding="0,0,0,2"/>
                        </Grid>
                    </Border>

                    <!-- Бюджет -->
                    <TextBlock Text="Бюджет" 
                   Style="{StaticResource FormLabelStyle}"/>
                    <Border Style="{StaticResource FormFieldStyle}">
                        <Grid>
                            <TextBox x:Name="TextBoxBudget"
                         VerticalAlignment="Center"
                         Background="Transparent"
                         BorderThickness="0"
                         FontSize="18"
                         Foreground="{StaticResource DarkText}"
                         VerticalContentAlignment="Center"
                         Padding="0,0,0,2"/>
                        </Grid>
                    </Border>

                    <!-- Описание -->
                    <TextBlock Text="Описание" 
                   Style="{StaticResource FormLabelStyle}"/>
                    <Border Style="{StaticResource FormFieldStyle}">
                        <Grid>
                            <TextBox x:Name="TextBoxDescription"
                         Background="Transparent"
                         BorderThickness="0"
                         FontSize="18"
                         Foreground="{StaticResource DarkText}"
                         VerticalContentAlignment="Top"
                         TextWrapping="Wrap"
                         AcceptsReturn="True"
                         Padding="0,8,0,8"
                         Height="60"/>
                        </Grid>
                    </Border>
                </StackPanel>
            </Grid>

            <!-- Кнопка сохранения - ТОЧНО ТАК ЖЕ -->
            <Button Grid.Row="3" x:Name="ButtonSave" 
                    Content="Сохранить мероприятие" 
                    Style="{StaticResource FormButtonStyle}"
                    HorizontalAlignment="Right"
                    VerticalAlignment="Bottom"
                    Click="BtnSave"
                    Width="250" Height="40"/>
        </Grid>
    </ScrollViewer>
</Page>
