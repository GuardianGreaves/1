<Page x:Class="diplom_loskutova.Page.AddOrChange.ApplicationsAOC"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
      xmlns:iconPacks="http://metro.mahapps.com/winfx/xaml/iconpacks"
      xmlns:local="clr-namespace:diplom_loskutova.Page.AddOrChange"
      mc:Ignorable="d" 
      Title="ApplicationsAOC">

    <Page.Resources>
        <!-- Цветовая схема -->
        <SolidColorBrush x:Key="PrimaryBlue" Color="#2196F3"/>
        <SolidColorBrush x:Key="LightBlue" Color="#E3F2FD"/>
        <SolidColorBrush x:Key="Blue50" Color="#BBDEFB"/>
        <SolidColorBrush x:Key="Blue100" Color="#90CAF9"/>
        <SolidColorBrush x:Key="Blue200" Color="#64B5F6"/>
        <SolidColorBrush x:Key="Blue400" Color="#2196F3"/>
        <SolidColorBrush x:Key="Blue500" Color="#1E88E5"/>
        <SolidColorBrush x:Key="Blue600" Color="#1976D2"/>
        <SolidColorBrush x:Key="White" Color="White"/>
        <SolidColorBrush x:Key="LightGray" Color="#F8F9FA"/>
        <SolidColorBrush x:Key="GrayText" Color="#6C757D"/>
        <SolidColorBrush x:Key="DarkText" Color="#2C3E50"/>

        <!-- Стиль поля ввода -->
        <Style x:Key="FormFieldStyle" TargetType="Border">
            <Setter Property="Background" Value="{StaticResource White}"/>
            <Setter Property="CornerRadius" Value="12"/>
            <Setter Property="BorderThickness" Value="2"/>
            <Setter Property="BorderBrush" Value="{StaticResource GrayText}"/>
            <Setter Property="Padding" Value="10"/>
            <Setter Property="Margin" Value="0,8"/>
            <Setter Property="Width" Value="500"/>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="BorderBrush" Value="{StaticResource Blue200}"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <!-- Стиль кнопки -->
        <Style x:Key="FormButtonStyle" TargetType="Button">
            <Setter Property="Background" Value="{StaticResource Blue400}"/>
            <Setter Property="Foreground" Value="{StaticResource White}"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="FontSize" Value="16"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Margin" Value="10"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}" CornerRadius="12" Padding="10">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Background" Value="{StaticResource Blue500}"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter Property="Background" Value="{StaticResource Blue600}"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Стиль кнопки назад -->
        <Style x:Key="BackButtonStyle" TargetType="Button">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="BorderBrush" Value="{StaticResource Blue400}"/>
            <Setter Property="Foreground" Value="{StaticResource Blue600}"/>
            <Setter Property="FontSize" Value="15"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}" 
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="10" Padding="10">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Background" Value="{StaticResource Blue50}"/>
                                <Setter Property="BorderBrush" Value="{StaticResource Blue600}"/>
                                <Setter Property="Foreground" Value="{StaticResource Blue600}"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Page.Resources>

    <ScrollViewer VerticalScrollBarVisibility="Hidden" Margin="5">
        <Grid Background="Transparent">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <!-- Верхняя панель -->
                <RowDefinition Height="Auto"/>
                <!-- Заголовок -->
                <RowDefinition Height="Auto"/>
                <!-- Форма -->
                <RowDefinition Height="*"/>
                <!-- Кнопки -->
            </Grid.RowDefinitions>

            <!-- Верхняя панель с кнопками -->
            <StackPanel Grid.Row="0" Orientation="Horizontal" Margin="0,0,0,32">
                <Button Style="{StaticResource BackButtonStyle}" Click="BtnBack">
                    <StackPanel Orientation="Horizontal">
                        <iconPacks:PackIconMaterial Kind="ArrowLeft" 
                                                  Width="18" Height="18"
                                                  Margin="0,0,8,0"
                                                  VerticalAlignment="Center"/>
                        <TextBlock Text="Назад"/>
                    </StackPanel>
                </Button>

                <Button Style="{StaticResource ButtomMenu}" Height="44" Margin="16,0,0,0" IsEnabled="False">
                    <TextBlock x:Name="NamePage" FontSize="16" 
                               Text="Заявка - Добавить / Редактировать" FontWeight="SemiBold"/>
                </Button>
            </StackPanel>

            <!-- Заголовок формы -->
            <TextBlock Grid.Row="1" 
                       Text="Заполните данные заявки" 
                       FontSize="28" FontWeight="SemiBold"
                       Foreground="{StaticResource Blue600}"
                       HorizontalAlignment="Center"
                       Margin="0,0,0,20"/>

            <!-- Форма ввода данных -->
            <StackPanel Grid.Row="2" Margin="10" >
                <!-- Пользователь -->
                <TextBlock Text="Пользователь" 
               FontSize="16" FontWeight="SemiBold"
               Foreground="{StaticResource Blue600}"
               Margin="0" Width="500"/>
                <Border Style="{StaticResource FormFieldStyle}">
                    <Grid>
                        <iconPacks:PackIconMaterial Kind="Account" 
                                      Width="20" Height="20"
                                      Foreground="{StaticResource Blue600}"
                                      VerticalAlignment="Center"
                                      Margin="0"/>
                        <ComboBox x:Name="ComboBoxUser"
                      VerticalAlignment="Center"
                      Background="Transparent"
                      BorderThickness="0"
                      FontSize="18"
                      Foreground="{StaticResource DarkText}"
                      VerticalContentAlignment="Center"
                      IsEditable="True"
                      Padding="0,0,0,2"/>
                    </Grid>
                </Border>

                <!-- Статус -->
                <TextBlock Text="Статус" 
               FontSize="16" FontWeight="SemiBold"
               Foreground="{StaticResource Blue600}"
               Margin="0,10,0,0" Width="500"/>
                <Border Style="{StaticResource FormFieldStyle}">
                    <Grid>
                        <iconPacks:PackIconMaterial Kind="FlagVariant" 
                                      Width="20" Height="20"
                                      Foreground="{StaticResource Blue600}"
                                      VerticalAlignment="Center"
                                      Margin="4,0,12,0"/>
                        <ComboBox x:Name="ComboBoxStatus"
                      VerticalAlignment="Center"
                      Background="Transparent"
                      BorderThickness="0"
                      FontSize="18"
                      Foreground="{StaticResource DarkText}"
                      VerticalContentAlignment="Center"
                      IsEditable="True"
                      Padding="0,0,0,2"/>
                    </Grid>
                </Border>

                <!-- Мероприятие -->
                <TextBlock Text="Мероприятие" 
               FontSize="16" FontWeight="SemiBold"
               Foreground="{StaticResource Blue600}"
               Margin="0,10,0,0" Width="500"/>
                <Border Style="{StaticResource FormFieldStyle}">
                    <Grid>
                        <iconPacks:PackIconMaterial Kind="Calendar" 
                                      Width="20" Height="20"
                                      Foreground="{StaticResource Blue600}"
                                      VerticalAlignment="Center"
                                      Margin="4,0,12,0"/>
                        <ComboBox x:Name="ComboBoxEvents"
                      VerticalAlignment="Center"
                      Background="Transparent"
                      BorderThickness="0"
                      FontSize="18"
                      Foreground="{StaticResource DarkText}"
                      VerticalContentAlignment="Center"
                      IsEditable="True"
                      Padding="0,0,0,2"/>
                    </Grid>
                </Border>
            </StackPanel>

            <!-- Кнопка сохранения -->
            <Button Grid.Row="3" x:Name="ButtonSave" 
                    Content="Сохранить заявку" 
                    Style="{StaticResource FormButtonStyle}"
                    HorizontalAlignment="Right"
                    VerticalAlignment="Bottom"
                    Click="BtnSave"
                    Width="200" Height="40"/>
        </Grid>
    </ScrollViewer>
</Page>
