<Page x:Class="diplom_loskutova.Page.AddOrChange.ApplicationsAOC"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
      xmlns:iconPacks="http://metro.mahapps.com/winfx/xaml/iconpacks"
      xmlns:local="clr-namespace:diplom_loskutova.Page.AddOrChange"
      mc:Ignorable="d" 
      Title="ApplicationsAOC">

    <ScrollViewer VerticalScrollBarVisibility="Hidden" Margin="5">
        <Grid Background="Transparent">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <!-- Верхняя панель -->
                <RowDefinition Height="Auto"/>
                <!-- Заголовок -->
                <RowDefinition Height="Auto"/>
                <!-- Форма -->
                <RowDefinition Height="*"/>
                <!-- Кнопки -->
            </Grid.RowDefinitions>

            <!-- Верхняя панель с кнопками -->
            <StackPanel Grid.Row="0" Orientation="Horizontal" Margin="0,0,0,32">
                <Button Style="{StaticResource BackButtonStyle}" Click="BtnBack">
                    <StackPanel Orientation="Horizontal">
                        <iconPacks:PackIconMaterial Kind="ArrowLeft" 
                                                  Width="18" Height="18"
                                                  Margin="0,0,8,0"
                                                  VerticalAlignment="Center"/>
                        <TextBlock Text="Назад"/>
                    </StackPanel>
                </Button>

                <Button Style="{StaticResource ButtomMenu}" Height="44" Margin="16,0,0,0" IsEnabled="False">
                    <TextBlock x:Name="NamePage" FontSize="16" 
                               Text="Заявка - Добавить / Редактировать" FontWeight="SemiBold"/>
                </Button>
            </StackPanel>

            <!-- Заголовок формы -->
            <TextBlock Grid.Row="1" 
                       Text="Заполните данные заявки" 
                       Style="{StaticResource PageHeaderStyle}"/>

            <!-- Форма ввода данных -->
            <StackPanel Grid.Row="2" Margin="10" >
                <!-- Пользователь -->
                <TextBlock Text="Пользователь" 
               Style="{StaticResource FormLabelStyle}"/>
                <Border Style="{StaticResource FormFieldStyle}">
                    <Grid>
                        <iconPacks:PackIconMaterial Kind="Account" 
                                      Width="20" Height="20"
                                      Foreground="{StaticResource Blue600}"
                                      VerticalAlignment="Center"
                                      Margin="0"/>
                        <ComboBox x:Name="ComboBoxUser"
                      VerticalAlignment="Center"
                      Background="Transparent"
                      BorderThickness="0"
                      FontSize="18"
                      Foreground="{StaticResource DarkText}"
                      VerticalContentAlignment="Center"
                      IsEditable="True"
                      Padding="0,0,0,2"/>
                    </Grid>
                </Border>

                <!-- Статус -->
                <TextBlock Text="Статус" 
               Style="{StaticResource FormLabelStyle}"/>
                <Border Style="{StaticResource FormFieldStyle}">
                    <Grid>
                        <iconPacks:PackIconMaterial Kind="FlagVariant" 
                                      Width="20" Height="20"
                                      Foreground="{StaticResource Blue600}"
                                      VerticalAlignment="Center"
                                      Margin="4,0,12,0"/>
                        <ComboBox x:Name="ComboBoxStatus"
                      VerticalAlignment="Center"
                      Background="Transparent"
                      BorderThickness="0"
                      FontSize="18"
                      Foreground="{StaticResource DarkText}"
                      VerticalContentAlignment="Center"
                      IsEditable="True"
                      Padding="0,0,0,2"/>
                    </Grid>
                </Border>

                <!-- Мероприятие -->
                <TextBlock Text="Мероприятие" 
               Style="{StaticResource FormLabelStyle}"/>
                <Border Style="{StaticResource FormFieldStyle}">
                    <Grid>
                        <iconPacks:PackIconMaterial Kind="Calendar" 
                                      Width="20" Height="20"
                                      Foreground="{StaticResource Blue600}"
                                      VerticalAlignment="Center"
                                      Margin="4,0,12,0"/>
                        <ComboBox x:Name="ComboBoxEvents"
                      VerticalAlignment="Center"
                      Background="Transparent"
                      BorderThickness="0"
                      FontSize="18"
                      Foreground="{StaticResource DarkText}"
                      VerticalContentAlignment="Center"
                      IsEditable="True"
                      Padding="0,0,0,2"/>
                    </Grid>
                </Border>
            </StackPanel>

            <!-- Кнопка сохранения -->
            <Button Grid.Row="3" x:Name="ButtonSave" 
                    Content="Сохранить заявку" 
                    Style="{StaticResource FormButtonStyle}"
                    HorizontalAlignment="Right"
                    VerticalAlignment="Bottom"
                    Click="BtnSave"
                    Width="200" Height="40"/>
        </Grid>
    </ScrollViewer>
</Page>
