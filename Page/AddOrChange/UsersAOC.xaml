<Page x:Class="diplom_loskutova.Page.AddOrChange.UsersAOC"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
      xmlns:iconPacks="http://metro.mahapps.com/winfx/xaml/iconpacks"
      xmlns:local="clr-namespace:diplom_loskutova.Page.AddOrChange"
      mc:Ignorable="d"
      Title="UsersAOC">

    <ScrollViewer VerticalScrollBarVisibility="Hidden" Margin="5">
        <Grid Background="Transparent">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <!-- Верхняя панель -->
                <RowDefinition Height="Auto"/>
                <!-- Заголовок -->
                <RowDefinition Height="Auto"/>
                <!-- Форма -->
                <RowDefinition Height="*"/>
                <!-- Кнопки -->
            </Grid.RowDefinitions>

            <!-- Верхняя панель с кнопками - ТОЧНО ТАК ЖЕ -->
            <StackPanel Grid.Row="0" Orientation="Horizontal" Margin="5">
                <Button Style="{StaticResource BackButtonStyle}" Click="BtnBack">
                    <StackPanel Orientation="Horizontal">
                        <iconPacks:PackIconMaterial Kind="ArrowLeft" 
                                                  Width="18" Height="18"
                                                  Margin="0,0,8,0"
                                                  VerticalAlignment="Center"/>
                        <TextBlock Text="Назад"/>
                    </StackPanel>
                </Button>

                <Button Style="{StaticResource ButtomMenu}" Height="44" Margin="16,0,0,0" IsEnabled="False">
                    <TextBlock x:Name="NamePage" FontSize="16" 
                               Text="Пользователь - Добавить / Редактировать" FontWeight="SemiBold"/>
                </Button>
            </StackPanel>

            <!-- Заголовок формы - ТОЧНО ТАК ЖЕ -->
            <TextBlock Grid.Row="1" 
                       Text="Заполните данные пользователя" 
                       Style="{StaticResource PageHeaderStyle}"/>

            <!-- Форма ввода данных - ТОЧНО ТАК ЖЕ (двухколоночная) -->
            <Grid Grid.Row="2" Margin="10">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <!-- Левый столбец -->
                    <ColumnDefinition Width="*"/>
                    <!-- Правый столбец -->
                </Grid.ColumnDefinitions>

                <!-- ЛЕВЫЙ СТОЛБЕЦ -->
                <StackPanel Grid.Column="0" Margin="0,0,20,0">
                    <!-- Роль -->
                    <TextBlock Text="Роль" Style="{StaticResource FormLabelStyle}"/>
                    <Border Style="{StaticResource FormFieldStyle}">
                        <Grid>
                            <ComboBox x:Name="ComboBoxRole"
                                      VerticalAlignment="Center"
                                      Background="Transparent"
                                      BorderThickness="0"
                                      FontSize="18"
                                      Foreground="{StaticResource DarkText}"
                                      VerticalContentAlignment="Center"
                                      IsEditable="True"
                                      Padding="0,0,0,2"/>
                        </Grid>
                    </Border>

                    <!-- Фамилия -->
                    <TextBlock Text="Фамилия" Style="{StaticResource FormLabelStyle}"/>
                    <Border Style="{StaticResource FormFieldStyle}">
                        <Grid>
                            <TextBox x:Name="TextBoxSurname"
                                     VerticalAlignment="Center"
                                     Background="Transparent"
                                     BorderThickness="0"
                                     FontSize="18"
                                     Foreground="{StaticResource DarkText}"
                                     VerticalContentAlignment="Center"
                                     Padding="0,0,0,2"/>
                        </Grid>
                    </Border>

                    <!-- Имя -->
                    <TextBlock Text="Имя" Style="{StaticResource FormLabelStyle}"/>
                    <Border Style="{StaticResource FormFieldStyle}">
                        <Grid>
                            <TextBox x:Name="TextBoxName"
                                     VerticalAlignment="Center"
                                     Background="Transparent"
                                     BorderThickness="0"
                                     FontSize="18"
                                     Foreground="{StaticResource DarkText}"
                                     VerticalContentAlignment="Center"
                                     Padding="0,0,0,2"/>
                        </Grid>
                    </Border>
                </StackPanel>

                <!-- ПРАВЫЙ СТОЛБЕЦ -->
                <StackPanel Grid.Column="1">
                    <!-- Отчество -->
                    <TextBlock Text="Отчество" Style="{StaticResource FormLabelStyle}"/>
                    <Border Style="{StaticResource FormFieldStyle}">
                        <Grid>
                            <TextBox x:Name="TextBoxPatronymic"
                                     VerticalAlignment="Center"
                                     Background="Transparent"
                                     BorderThickness="0"
                                     FontSize="18"
                                     Foreground="{StaticResource DarkText}"
                                     VerticalContentAlignment="Center"
                                     Padding="0,0,0,2"/>
                        </Grid>
                    </Border>

                    <!-- Логин -->
                    <TextBlock Text="Логин" Style="{StaticResource FormLabelStyle}"/>
                    <Border Style="{StaticResource FormFieldStyle}">
                        <Grid>
                            <TextBox x:Name="TextBoxLogin"
                                     VerticalAlignment="Center"
                                     Background="Transparent"
                                     BorderThickness="0"
                                     FontSize="18"
                                     Foreground="{StaticResource DarkText}"
                                     VerticalContentAlignment="Center"
                                     Padding="0,0,0,2"/>
                        </Grid>
                    </Border>

                    <!-- Пароль -->
                    <TextBlock Text="Пароль" Style="{StaticResource FormLabelStyle}"/>
                    <Border Style="{StaticResource FormFieldStyle}">
                        <Grid>
                            <PasswordBox x:Name="TextBoxPassword"
                                         VerticalAlignment="Center"
                                         Background="Transparent"
                                         BorderThickness="0"
                                         FontSize="18"
                                         VerticalContentAlignment="Center"/>
                        </Grid>
                    </Border>
                </StackPanel>
            </Grid>

            <!-- Кнопка сохранения - ТОЧНО ТАК ЖЕ -->
            <Button Grid.Row="3" x:Name="ButtonSave" 
                    Content="Сохранить пользователя" 
                    Style="{StaticResource FormButtonStyle}"
                    HorizontalAlignment="Right"
                    VerticalAlignment="Bottom"
                    Click="BtnSave"
                    Width="250" Height="40"/>
        </Grid>
    </ScrollViewer>
</Page>
