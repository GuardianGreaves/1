<Page x:Class="diplom_loskutova.Page.TypeEvent"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
      xmlns:local="clr-namespace:diplom_loskutova.Page"
      mc:Ignorable="d" 
      Title="Типы мероприятий">

    <Grid Style="{StaticResource DefaultPage}">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <!-- Заголовок + кнопки -->
            <RowDefinition Height="*"/>
            <!-- ListView + правая панель -->
            <RowDefinition Height="Auto"/>
            <!-- Статистика снизу -->
        </Grid.RowDefinitions>

        <!-- Заголовок и кнопки действий - ТОЧНО ТАК ЖЕ -->
        <Grid Style="{StaticResource PageHeaderGridStyle}" Grid.Row="0">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>

            <TextBlock Grid.Column="0" 
                       Text="Типы мероприятий" 
                       Style="{StaticResource PageTitleStyle}"/>

            <StackPanel Grid.Column="1" Orientation="Horizontal" HorizontalAlignment="Right">
                <Button x:Name="btnChange" Content="Редактировать" Style="{StaticResource ActionButtonStyle}" Click="BtnChange"/>
                <Button x:Name="btnAdd" Content="Добавить" Style="{StaticResource ActionButtonStyle}" Click="BtnAdd"/>
                <Button x:Name="btnDelete" Content="Удалить" Style="{StaticResource ActionButtonStyle}" Click="BtnDelete"/>
            </StackPanel>
        </Grid>

        <!-- ListView + Панель фильтров - ТОЧНО ТА же структура -->
        <Grid Grid.Row="1">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="2*"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <!-- Список типов мероприятий - ТОЧНО ТАК ЖЕ -->
            <Border Grid.Column="0" Background="{StaticResource White}" 
                    CornerRadius="16" Margin="5 0 5 5" Padding="5">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="*"/>
                        <!-- ListView -->
                        <RowDefinition Height="Auto"/>
                        <!-- Статистика -->
                    </Grid.RowDefinitions>

                    <!-- ListView -->
                    <ListView Grid.Row="0" x:Name="listViewTypeEvent" 
                              MouseDoubleClick="ListViewStatus_MouseDoubleClick"
                              ItemsSource="{Binding}"
                              Padding="0">
                        <ListView.View>
                            <GridView AllowsColumnReorder="False">
                                <GridViewColumn Header="ID" DisplayMemberBinding="{Binding [ID_Типа]}" Width="auto"/>
                                <GridViewColumn Header="Название" DisplayMemberBinding="{Binding [Название]}" Width="auto"/>
                                <GridViewColumn Header="Описание" DisplayMemberBinding="{Binding [Описание]}" Width="auto"/>
                            </GridView>
                        </ListView.View>
                    </ListView>

                    <!-- Статистика + пагинация ВНУТРИ Border - ТОЧНО ТАК ЖЕ -->
                    <Grid Grid.Row="1" Margin="10">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"/>
                            <!-- Страница -->
                            <ColumnDefinition Width="*"/>
                            <!-- Записей X из Y -->
                            <ColumnDefinition Width="Auto"/>
                            <!-- Навигация -->
                        </Grid.ColumnDefinitions>

                        <TextBlock Grid.Column="0" 
                                   x:Name="tbPageNumber"
                                   Text="Страница 1" 
                                   FontSize="14"
                                   Foreground="{StaticResource Blue600}"
                                   FontWeight="SemiBold"
                                   VerticalAlignment="Center"
                                   Margin="0,0,20,0"/>

                        <TextBlock Grid.Column="1" 
                                   x:Name="tbRecordsInfo"
                                   Text="Записей 15 из 34" 
                                   FontSize="14"
                                   Foreground="{StaticResource GrayText}"
                                   HorizontalAlignment="Center"
                                   VerticalAlignment="Center"/>

                        <StackPanel Grid.Column="2" Orientation="Horizontal" HorizontalAlignment="Right" Width="75">
                            <Button x:Name="btnPrev" 
                                    Width="30" Height="25" 
                                    Content="‹" 
                                    Margin="0,0,5,0"
                                    Style="{StaticResource ActionButtonStyle}"
                                    Click="BtnPrev_Click"/>
                            <Button x:Name="btnNext" 
                                    Width="30" Height="25" 
                                    Content="›"
                                    Style="{StaticResource ActionButtonStyle}"
                                    Click="BtnNext_Click"/>
                        </StackPanel>
                    </Grid>


                </Grid>
            </Border>

            
            
            <!-- Панель фильтров - ТОЧНО ТА же структура -->
            <Border Grid.Column="1" Background="{StaticResource White}" 
                    CornerRadius="16" Margin="5 0 5 5" Padding="5">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <!-- Фильтры - ТОЧНО ТАК ЖЕ -->
                    <Border Grid.Row="0" Background="Transparent"
                            CornerRadius="12" Padding="5" Margin="0">
                        <StackPanel>
                            <TextBlock Text="Фильтры" 
                                       FontSize="18" FontWeight="SemiBold" 
                                       Foreground="{StaticResource Blue600}" 
                                       Margin="0,0,16,10"/>

                            <!-- Поиск по названию -->
                            <StackPanel Margin="0,0,0,12">
                                <TextBlock Text="Поиск по названию" 
                                           FontSize="14" Margin="0,0,4,0" 
                                           Foreground="{StaticResource GrayText}"/>
                                <TextBox x:Name="TextBoxSearchName" 
                                         Height="25" 
                                         Background="{StaticResource White}" 
                                         BorderBrush="{StaticResource Blue200}"
                                         TextChanged="TextBoxSearchName_TextChanged"/>
                            </StackPanel>

                            <!-- Кнопка сброса фильтра -->
                            <Button Content="Сбросить фильтр" 
                                    Style="{StaticResource ActionButtonStyle}" 
                                    Click="BtnResetFilter_Click" 
                                    HorizontalAlignment="Right"/>
                        </StackPanel>
                    </Border>

                    <!-- Нижняя часть справа (пустая для симметрии) -->
                    <Border Grid.Row="1" Background="{StaticResource White}" 
                            CornerRadius="12" Padding="5" Margin="5">
                        <Grid>
                            <!-- Здесь можно добавить график или доп. информацию -->
                        </Grid>
                    </Border>
                </Grid>
            </Border>
        </Grid>

        <!-- Нижняя строка (если не нужна, можно удалить RowDefinition и этот Grid.Row=2) -->
        <Grid Grid.Row="2">
            <!-- Пока пусто -->
        </Grid>
    </Grid>
</Page>
