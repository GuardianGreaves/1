<Page x:Class="diplom_loskutova.Page.RoleUser"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
      mc:Ignorable="d"
      Title="Роли пользователей">

    <Grid Style="{StaticResource DefaultPage}">
        <Grid.RowDefinitions>
            <!-- Заголовок + кнопки -->
            <RowDefinition Height="Auto"/>
            <!-- Левая таблица + правая панель -->
            <RowDefinition Height="*"/>
            <!-- Статистика снизу (если захочешь, можно добавить) -->
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Заголовок и кнопки действий -->
        <Grid Style="{StaticResource PageHeaderGridStyle}" Grid.Row="0">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>

            <!-- Заголовок страницы -->
            <TextBlock Grid.Column="0"
                       Text="Роли пользователей"
                       Style="{StaticResource PageTitleStyle}"/>

            <!-- Кнопки действий справа -->
            <StackPanel Grid.Column="1" Orientation="Horizontal" HorizontalAlignment="Right">
                <Button x:Name="btnChange"
                        Content="Редактировать"
                        Style="{StaticResource ActionButtonStyle}"
                        Click="BtnChange"/>
                <Button x:Name="btnAdd"
                        Content="Добавить"
                        Style="{StaticResource ActionButtonStyle}"
                        Click="BtnAdd"/>
                <Button x:Name="btnDelete"
                        Content="Удалить"
                        Style="{StaticResource ActionButtonStyle}"
                        Click="BtnDelete"/>
            </StackPanel>
        </Grid>

        <!-- Основное содержимое: список ролей + правая панель фильтров -->
        <Grid Grid.Row="1">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="2*"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <!-- Левая карточка со списком ролей -->
            <Border Grid.Column="0"
                    Background="{StaticResource White}"
                    CornerRadius="16"
                    Margin="5 0 5 5"
                    Padding="5">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="*"/>
                        <!-- ListView -->
                        <RowDefinition Height="Auto"/>
                        <!-- Статистика -->
                    </Grid.RowDefinitions>

                    <!-- Список ролей -->
                    <ListView Grid.Row="0"
                              x:Name="listViewRoleUser"
                              MouseDoubleClick="ListViewStatus_MouseDoubleClick"
                              Padding="0"
                              ItemsSource="{Binding}">
                        <ListView.View>
                            <GridView AllowsColumnReorder="False">
                                <GridViewColumn Header="ID"
                                                DisplayMemberBinding="{Binding [ID_Статуса]}"
                                                Width="auto"/>
                                <GridViewColumn Header="Название"
                                                DisplayMemberBinding="{Binding [Название]}"
                                                Width="auto"/>
                                <GridViewColumn Header="Описание"
                                                DisplayMemberBinding="{Binding [Описание]}"
                                                Width="auto"/>
                                <GridViewColumn Header="Права"
                                                DisplayMemberBinding="{Binding [Права_Доступа]}"
                                                Width="auto"/>
                            </GridView>
                        </ListView.View>
                    </ListView>
                </Grid>
            </Border>

            <!-- Правая панель с фильтрами -->
            <Border Grid.Column="1"
                    Background="{StaticResource White}"
                    CornerRadius="16"
                    Margin="5 0 5 5"
                    Padding="5">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <!-- Блок фильтров (в том же визуальном стиле) -->
                    <Border Grid.Row="0"
                            Background="Transparent"
                            CornerRadius="12"
                            Padding="5"
                            Margin="0">
                        <StackPanel>
                            <TextBlock Text="Фильтры"
                                       FontSize="18"
                                       FontWeight="SemiBold"
                                       Foreground="{StaticResource Blue600}"
                                       Margin="0,0,16,10"/>

                            <!-- Поиск по названию -->
                            <StackPanel Margin="0,0,0,12">
                                <TextBlock Text="Поиск по названию"
                                           FontSize="14"
                                           Margin="0,0,4,0"
                                           Foreground="{StaticResource GrayText}"/>
                                <TextBox x:Name="TextBoxSearchName"
                                         Height="25"
                                         Background="{StaticResource White}"
                                         BorderBrush="{StaticResource Blue200}"
                                         TextChanged="TextBoxSearchName_TextChanged"/>
                            </StackPanel>

                            <!-- Кнопка сброса фильтра -->
                            <Button Content="Сбросить фильтр"
                                    Style="{StaticResource ActionButtonStyle}"
                                    Click="BtnResetFilter_Click"
                                    HorizontalAlignment="Right"/>
                        </StackPanel>
                    </Border>

                    <!-- Нижняя часть справа (пока пустая, можно использовать под доп. инфу/график) -->
                    <Border Grid.Row="1"
                            Background="{StaticResource White}"
                            CornerRadius="12"
                            Padding="5"
                            Margin="5">
                        <Grid>
                            <!-- Здесь при необходимости можно добавить график или детали по выбранной роли -->
                        </Grid>
                    </Border>
                </Grid>
            </Border>
        </Grid>

        <!-- Нижняя строка (если не нужна, можно удалить RowDefinition и этот Grid.Row=2) -->
        <Grid Grid.Row="2">
            <!-- Пока пусто -->
        </Grid>
    </Grid>
</Page>
