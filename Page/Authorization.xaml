<Page x:Class="diplom_loskutova.Page.Authorization"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:iconPacks="http://metro.mahapps.com/winfx/xaml/iconpacks"
      Title="Authorization">

    <Page.Resources>
        <!-- Цветовая схема из главного окна -->
        <SolidColorBrush x:Key="PrimaryBlue" Color="#2196F3"/>
        <SolidColorBrush x:Key="LightBlue" Color="#E3F2FD"/>
        <SolidColorBrush x:Key="Blue50" Color="#BBDEFB"/>
        <SolidColorBrush x:Key="Blue100" Color="#90CAF9"/>
        <SolidColorBrush x:Key="Blue200" Color="#64B5F6"/>
        <SolidColorBrush x:Key="Blue300" Color="#42A5F5"/>
        <SolidColorBrush x:Key="Blue400" Color="#2196F3"/>
        <SolidColorBrush x:Key="Blue500" Color="#1E88E5"/>
        <SolidColorBrush x:Key="Blue600" Color="#1976D2"/>
        <SolidColorBrush x:Key="Blue700" Color="#1565C0"/>
        <SolidColorBrush x:Key="White" Color="White"/>
        <SolidColorBrush x:Key="LightGray" Color="#F8F9FA"/>
        <SolidColorBrush x:Key="GrayText" Color="#6C757D"/>
        <SolidColorBrush x:Key="DarkText" Color="#2C3E50"/>

        <!-- Стиль текстового поля -->
        <Style x:Key="TextFieldStyle" TargetType="Border">
            <Setter Property="CornerRadius" Value="12"/>
            <Setter Property="BorderThickness" Value="2"/>
            <Setter Property="BorderBrush" Value="{StaticResource Blue400}"/>
            <Setter Property="Background" Value="{StaticResource White}"/>
            <Setter Property="Effect">
                <Setter.Value>
                    <DropShadowEffect Color="Gray" Direction="270" ShadowDepth="1" BlurRadius="8" Opacity="0.15"/>
                </Setter.Value>
            </Setter>
            <Style.Triggers>
                <DataTrigger Binding="{Binding RelativeSource={RelativeSource Self}, Path=Tag}" Value="Focused">
                    <Setter Property="BorderBrush" Value="{StaticResource Blue400}"/>
                    <Setter Property="BorderThickness" Value="2"/>
                </DataTrigger>
                <DataTrigger Binding="{Binding RelativeSource={RelativeSource Self}, Path=Tag}" Value="Filled">
                    <Setter Property="BorderBrush" Value="{StaticResource Blue200}"/>
                </DataTrigger>
            </Style.Triggers>
        </Style>

        <!-- Стиль кнопки входа -->
        <Style x:Key="LoginButtonStyle" TargetType="Button">
            <Setter Property="Background" Value="{StaticResource Blue400}"/>
            <Setter Property="Foreground" Value="{StaticResource White}"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="FontSize" Value="18"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Padding" Value="32,16"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}" 
                                CornerRadius="12"
                                Padding="40 0 40 0">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Background" Value="{StaticResource Blue500}"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="GuestButtonStyle" TargetType="Button">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Foreground" Value="{StaticResource Blue400}"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="FontSize" Value="18"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Padding" Value="32,16"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}" 
                                CornerRadius="12"
                                Padding="20 0 20 0">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Background" Value="{StaticResource Blue500}"/>
                                <Setter Property="Foreground" Value="{StaticResource White}"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

    </Page.Resources>

    <Grid>
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <!-- Заголовок -->
            <TextBlock Grid.Row="1" 
                       Text="Авторизация" 
                       FontSize="48" 
                       FontWeight="Light"
                       Foreground="{StaticResource Blue700}"
                       HorizontalAlignment="Center"
                       VerticalAlignment="Center"
                       Margin="0,0,0,40"/>

            <!-- Поле логина -->
            <Border x:Name="LoginBorder" Grid.Row="2" 
                    Style="{StaticResource TextFieldStyle}"
                    Width="420" Height="64" Margin="0,0,0,24"
                    Tag="Empty">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>

                    <!-- Иконка -->
                    <Border Grid.Column="0" Width="52" Height="52" 
                            Background="Transparent" 
                            CornerRadius="26" 
                            VerticalAlignment="Center" Margin="10,0,10,0">
                        <iconPacks:PackIconMaterial Kind="EmailOutline" 
                                                  Width="24" Height="24" 
                                                  Foreground="{StaticResource Blue600}"
                                                  HorizontalAlignment="Center" 
                                                  VerticalAlignment="Center"/>
                    </Border>

                    <!-- Текстовое поле -->
                    <TextBox x:Name="TextBoxLogin" 
                             Grid.Column="1" 
                             FontSize="20" 
                             VerticalAlignment="Center" 
                             Background="Transparent" 
                             BorderThickness="0"
                             Padding="0,0,0,0"
                             TextChanged="TextBoxLogin_TextChanged"
                             Foreground="{StaticResource DarkText}"
                             CaretBrush="{StaticResource Blue400}"
                             VerticalContentAlignment="Center"
                             Height="45"/>

                    <!-- Подсказка -->
                    <TextBlock x:Name="TextBlockLogin" 
                               Grid.Column="1" 
                               Text="Логин" 
                               FontSize="18" 
                               Foreground="{StaticResource GrayText}"
                               VerticalAlignment="Center"
                               Margin="3,0,0,0"
                               IsHitTestVisible="False"/>
                </Grid>
            </Border>

            <!-- Поле пароля -->
            <Border x:Name="PasswordBorder" Grid.Row="3" 
                    Style="{StaticResource TextFieldStyle}"
                    Width="420" Height="64" Margin="0,0,0,32"
                    Tag="Empty">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>

                    <!-- Иконка -->
                    <Border Grid.Column="0" Width="52" Height="52" 
                            Background="Transparent" 
                            CornerRadius="26" 
                            VerticalAlignment="Center" Margin="10,0,10,0">
                        <iconPacks:PackIconMaterial Kind="LockOutline" 
                                                  Width="24" Height="24" 
                                                  Foreground="{StaticResource Blue600}"
                                                  HorizontalAlignment="Center" 
                                                  VerticalAlignment="Center"/>
                    </Border>

                    <!-- Парольное поле -->
                    <PasswordBox x:Name="TextBoxPassword" 
                                 Grid.Column="1" 
                                 FontSize="20" 
                                 VerticalAlignment="Center"
                                 VerticalContentAlignment="Center"
                                 Background="Transparent" 
                                 BorderThickness="0"
                                 Padding="0,0,0,0"
                                 PasswordChanged="TextBoxPassword_PasswordChanged"
                                 Foreground="{StaticResource DarkText}"
                                 CaretBrush="{StaticResource Blue400}"
                                 Height="45"/>

                    <!-- Подсказка -->
                    <TextBlock x:Name="TextBlockPassword" 
                               Grid.Column="1" 
                               Text="Пароль" 
                               FontSize="18" 
                               Foreground="{StaticResource GrayText}"
                               VerticalAlignment="Center"
                               Margin="3,0,0,0"
                               IsHitTestVisible="False"/>
                </Grid>
            </Border>

            <Grid Grid.Row="4">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <Button x:Name="SignIn"
                    Grid.Column="1"
                    HorizontalAlignment="Right"
                    Content="Войти" 
                    Style="{StaticResource LoginButtonStyle}"
                    Height="60"
                    Click="SignIn_Click"/>
                <Button x:Name="GuestIn"                     
                    Grid.Column="0"
                    HorizontalAlignment="Left"
                    Content="Гостевой режим" 
                    Style="{StaticResource GuestButtonStyle}"
                    Height="60"
                    Click="GuestIn_Click"/>
                <!-- Измените обработчик, если нужно -->
            </Grid>
        </Grid>
    </Grid>
</Page>
