<UserControl x:Class="diplom_loskutova.UserControlReport"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:diplom_loskutova" xmlns:ScottPlot="http://schemas.scottplot.net/2008/xaml/presentation"
             mc:Ignorable="d" 
             d:DesignHeight="450" d:DesignWidth="800">

    <Grid Style="{StaticResource DefaultPage}">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <!-- Заголовок -->
            <RowDefinition Height="Auto"/>
            <!-- Кнопки экспорта -->
            <RowDefinition Height="Auto"/>
            <!-- Фильтры -->
            <RowDefinition Height="*"/>
            <!-- DataGrid -->
        </Grid.RowDefinitions>

        <!-- 1. Заголовок -->
        <Grid Style="{StaticResource PageHeaderGridStyle}" Grid.Row="0">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>

            <TextBlock Grid.Column="0" 
                       x:Name="NameReport"
                       Text="Отчеты" 
                       Style="{StaticResource PageTitleStyle}"/>

            <!-- Кнопки экспорта -->
            <StackPanel Grid.Column="1" Orientation="Horizontal" HorizontalAlignment="Right">
                <Button Style="{StaticResource ActionButtonStyle}" 
                        Height="36" Width="100" 
                        Content="Word" 
                        Click="Button_Click"/>
                <Button Style="{StaticResource ActionButtonStyle}" 
                        Height="36" Width="100"
                        Content="Excel" 
                        Click="Button_Click_1"/>
                <Button Style="{StaticResource ActionButtonStyle}" 
                        Height="36" Width="100"
                        Content="Печать" 
                        Click="PrintButton_Click"/>
            </StackPanel>
        </Grid>

        <!-- 2. Фильтры (в стиле FormFieldStyle) -->
        <Border Grid.Row="2">
            <StackPanel Orientation="Horizontal" HorizontalAlignment="Left">
                <!-- Фильтр по мероприятию -->
                <StackPanel x:Name="filterEvent" Margin="10,5,10,5" Visibility="Collapsed">
                    <TextBlock Text="Мероприятие" 
                               Style="{StaticResource FormLabelStyle}"
                               Margin="0,0,0,0"/>
                    <Border Style="{StaticResource FormFieldStyle}">
                        <ComboBox x:Name="cbEvents" 
                                  DisplayMemberPath="Название"
                                  SelectedValuePath="ID_Мероприятия"
                                  Background="Transparent"
                                  BorderThickness="0"
                                  FontSize="16"
                                  VerticalContentAlignment="Center"
                                  SelectionChanged="cbEvents_SelectionChanged"/>
                    </Border>
                </StackPanel>

                <!-- Фильтр по дате -->
                <StackPanel x:Name="filter" Margin="15,0,0,0" Visibility="Collapsed">
                    <TextBlock Text="Дата" 
                               Style="{StaticResource FormLabelStyle}"
                               Margin="0,0,0,4"/>
                    <Border Style="{StaticResource FormFieldStyle}">
                        <DatePicker x:Name="filterDate" 
                                    Background="Transparent"
                                    BorderThickness="0"
                                    FontSize="16"
                                    VerticalContentAlignment="Center"
                                    SelectedDateChanged="filterDate_SelectedDateChanged"/>
                    </Border>
                </StackPanel>
            </StackPanel>
        </Border>

        <!-- 3. DataGrid в карточке -->
        <Border Grid.Row="3" Style="{StaticResource ListCardStyle}" Margin="10">
            <Grid x:Name="mainGrid">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition x:Name="dataGridColumn" Width="*"/>
                    <ColumnDefinition x:Name="chartColumn" Width="0"/>
                </Grid.ColumnDefinitions>

                <!-- DataGrid всегда на всю доступную ширину -->
                <DataGrid x:Name="dataGridReport" 
                  Grid.Column="0" 
                  SelectionChanged="dataGridReport_SelectionChanged"/>

                <!-- Диаграмма (скрывается/показывается через Width) -->
                <Border x:Name="chartBorder" 
                    Grid.Column="1" 
                    Background="White" 
                    BorderBrush="#E0E0E0" 
                    BorderThickness="1" 
                    CornerRadius="4"
                    Margin="5,0,0,0"
                    Visibility="Visible">
                    <!-- УБИРАЕМ лишний Border с Grid.Row -->
                    <ScottPlot:WpfPlot x:Name="WpfPlot1" />
                </Border>
            </Grid>
        </Border>
    </Grid>
</UserControl>
