<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:Icon="http://metro.mahapps.com/winfx/xaml/iconpacks"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <SolidColorBrush x:Key="PrimaryBlue" Color="#2196F3"/>
    <SolidColorBrush x:Key="LightBlue" Color="#E3F2FD"/>
    <SolidColorBrush x:Key="Blue50" Color="#BBDEFB"/>
    <SolidColorBrush x:Key="Blue100" Color="#90CAF9"/>
    <SolidColorBrush x:Key="Blue200" Color="#64B5F6"/>
    <SolidColorBrush x:Key="Blue400" Color="#2196F3"/>
    <SolidColorBrush x:Key="Blue500" Color="#1E88E5"/>
    <SolidColorBrush x:Key="Blue600" Color="#1976D2"/>
    <SolidColorBrush x:Key="White" Color="White"/>
    <SolidColorBrush x:Key="LightGray" Color="#F8F9FA"/>
    <SolidColorBrush x:Key="GrayText" Color="#6C757D"/>
    <SolidColorBrush x:Key="DarkText" Color="#2C3E50"/>

    <!-- В ResourceDictionary -->
    <Style x:Key="PageHeaderStyle" TargetType="TextBlock">
        <Setter Property="FontSize" Value="28"/>
        <Setter Property="FontWeight" Value="SemiBold"/>
        <Setter Property="Foreground" Value="{StaticResource Blue600}"/>
        <Setter Property="HorizontalAlignment" Value="Center"/>
        <Setter Property="Margin" Value="0,0,0,20"/>
        <Setter Property="TextAlignment" Value="Center"/>
    </Style>

    <Style x:Key="PageTitleStyle" TargetType="TextBlock">
        <Setter Property="FontSize" Value="28"/>
        <Setter Property="FontWeight" Value="SemiBold"/>
        <Setter Property="Foreground" Value="{StaticResource Blue600}"/>
        <Setter Property="HorizontalAlignment" Value="Left"/>
        <Setter Property="Margin" Value="0,0,0,0"/>
        <Setter Property="TextAlignment" Value="Center"/>
    </Style>

    <Style x:Key="FormLabelStyle" TargetType="TextBlock">
        <Setter Property="FontSize" Value="16"/>
        <Setter Property="FontWeight" Value="SemiBold"/>
        <Setter Property="Foreground" Value="{StaticResource Blue600}"/>
        <Setter Property="Margin" Value="0"/>
        <Setter Property="Width" Value="400"/>
        <Setter Property="VerticalAlignment" Value="Center"/>
    </Style>

</ResourceDictionary>