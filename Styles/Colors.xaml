<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <!-- БЛКИ СИНИЕ -->
    <SolidColorBrush x:Key="PrimaryBlue" Color="#2196F3"/>
    <SolidColorBrush x:Key="LightBlue" Color="#E3F2FD"/>
    <SolidColorBrush x:Key="Blue50" Color="#BBDEFB"/>
    <SolidColorBrush x:Key="Blue100" Color="#90CAF9"/>
    <SolidColorBrush x:Key="Blue200" Color="#64B5F6"/>
    <SolidColorBrush x:Key="Blue400" Color="#2196F3"/>
    <SolidColorBrush x:Key="Blue500" Color="#1E88E5"/>
    <SolidColorBrush x:Key="Blue600" Color="#1976D2"/>
    <SolidColorBrush x:Key="Blue700" Color="#1565C0"/>
    <SolidColorBrush x:Key="Blue800" Color="#0D47A1"/>

    <!-- ОСНОВНЫЕ -->
    <SolidColorBrush x:Key="White" Color="White"/>
    <SolidColorBrush x:Key="LightGray" Color="#F8F9FA"/>
    <SolidColorBrush x:Key="GrayText" Color="#6C757D"/>
    <SolidColorBrush x:Key="DarkText" Color="#2C3E50"/>

</ResourceDictionary>
