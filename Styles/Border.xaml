<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:Icon="http://metro.mahapps.com/winfx/xaml/iconpacks"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <SolidColorBrush x:Key="PrimaryBlue" Color="#2196F3"/>
    <SolidColorBrush x:Key="LightBlue" Color="#E3F2FD"/>
    <SolidColorBrush x:Key="Blue50" Color="#BBDEFB"/>
    <SolidColorBrush x:Key="Blue100" Color="#90CAF9"/>
    <SolidColorBrush x:Key="Blue200" Color="#64B5F6"/>
    <SolidColorBrush x:Key="Blue400" Color="#2196F3"/>
    <SolidColorBrush x:Key="Blue500" Color="#1E88E5"/>
    <SolidColorBrush x:Key="Blue600" Color="#1976D2"/>
    <SolidColorBrush x:Key="White" Color="White"/>
    <SolidColorBrush x:Key="LightGray" Color="#F8F9FA"/>
    <SolidColorBrush x:Key="GrayText" Color="#6C757D"/>
    <SolidColorBrush x:Key="DarkText" Color="#2C3E50"/>

    <Style x:Key="StatCardStyle" TargetType="Border">
        <Setter Property="Background" Value="{StaticResource White}"/>
        <Setter Property="CornerRadius" Value="16"/>
        <Setter Property="BorderThickness" Value="2"/>
        <Setter Property="BorderBrush" Value="{StaticResource Blue50}"/>
        <Setter Property="Padding" Value="10"/>
        <Setter Property="Margin" Value="10"/>
    </Style>


    <Style x:Key="FormFieldStyle" TargetType="Border">
        <Setter Property="Background" Value="{StaticResource White}"/>
        <Setter Property="CornerRadius" Value="15"/>
        <Setter Property="BorderThickness" Value="2"/>
        <Setter Property="BorderBrush" Value="{StaticResource GrayText}"/>
        <Setter Property="Padding" Value="10"/>
        <Setter Property="Margin" Value="0 5"/>
        <Setter Property="Width" Value="400"/>
        <Style.Triggers>
            <Trigger Property="IsMouseOver" Value="True">
                <Setter Property="BorderBrush" Value="{StaticResource Blue200}"/>
            </Trigger>
        </Style.Triggers>
    </Style>

</ResourceDictionary>